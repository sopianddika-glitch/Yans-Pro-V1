{
    "name": "yans-pro",
    "version": "1.0.0",
    "description": "A professional business finance tracker with AI-powered insights.",
    "main": "src/main.cjs",
    "type": "module",
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@google/genai": "^1.11.0",
        "framer-motion": "^11.0.0",
        "html5-qrcode": "^2.3.8",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-is": "^19.2.4",
        "recharts": "^3.1.0",
        "serve": "^14.2.1",
        "zustand": "^4.4.0"
    },
    "devDependencies": {
        "@babel/preset-react": "^7.23.0",
        "@testing-library/jest-dom": "^6.1.5",
        "@testing-library/react": "^14.1.0",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.2",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "@vitejs/plugin-react": "^4.2.0",
        "babel-jest": "^29.7.0",
        "electron": "^40.0.0",
        "electron-builder": "^24.13.3",
        "eslint": "^8.54.0",
        "eslint-plugin-react": "^7.33.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "jest": "^29.7.0",
        "markdownlint-cli": "^0.35.0",
        "prettier": "^3.1.0",
        "terser": "^5.46.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0"
    },
    "scripts": {
        "dev": "vite",
        "start": "vite",
        "build:web": "vite build",
        "build:app": "electron-builder build --win",
        "build": "npm run build:web && npm run build:app",
        "preview": "vite preview",
        "serve": "serve -s dist -l 3000",
        "deploy": "npm run build:web && echo 'Ready for GitHub Pages deployment'",
        "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "lint:markdown": "markdownlint **/*.md -f",
        "format": "prettier --write src && prettier --write '**/*.md'",
        "format:check": "prettier --check src && markdownlint **/*.md",
        "type-check": "tsc --noEmit",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch --passWithNoTests",
        "test:coverage": "jest --coverage --passWithNoTests",
        "qa": "npm run lint && npm run lint:markdown && npm run type-check && npm run test"
    }
}
